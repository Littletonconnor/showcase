# Flat node_modules (npm-like) so transitive imports the source already relies
# on (e.g. shiki's @shikijs/* engines) keep resolving across the workspace.
# The package boundary that matters — core has no node: imports, the CLI pulls
# no React — is enforced by the import graph and per-package deps, not by
# pnpm's physical layout. Revisit (strict + explicit deps) as a follow-up.
shamefully-hoist=true
