{
  // Repo-level program for the cross-package test suite (test/). Each package
  // has its own tsconfig; this one covers the tests that import the @showcase/*
  // packages by name. The `@/*` alias is mirrored here (inert for tests) so the
  // shadcn CLI, which reads the default tsconfig, still resolves viewer paths.
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "paths": { "@/*": ["./packages/viewer/src/*"] }
  },
  "include": ["test"]
}
