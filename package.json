{
  "name": "showcase",
  "version": "0.1.0",
  "private": true,
  "description": "A live visual surface for terminal coding agents — agents publish surfaces (diagrams, diffs, markdown, mermaid, html) and you watch them render in the browser and comment back.",
  "license": "MIT",
  "bin": {
    "showcase": "bin/showcase.js"
  },
  "type": "module",
  "scripts": {
    "dev": "vite build && (vite build --watch & node --watch server/index.ts)",
    "start": "vite build && node server/index.ts",
    "serve": "node bin/showcase.js serve",
    "build:viewer": "vite build",
    "mcp": "node mcp/server.ts",
    "test": "node --test 'test/**/*.test.ts'",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.viewer.json --noEmit",
    "lint": "oxlint . --deny-warnings",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@pierre/diffs": "^1.2.11",
    "ansi_up": "^6.0.6",
    "hono": "^4.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.3",
    "markdown-it": "^14.2.0",
    "mermaid": "^11.15.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "shiki": "^4.2.0",
    "solid-js": "^1.9.13",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-singlefile": "^2.3.3",
    "vite-plugin-solid": "^2.11.12"
  },
  "engines": {
    "node": ">=22.18"
  }
}
