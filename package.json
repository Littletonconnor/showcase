{
  "name": "showcase",
  "version": "0.1.0",
  "private": true,
  "description": "A live visual surface for terminal coding agents — agents publish surfaces (diagrams, diffs, markdown, mermaid, html) and you watch them render in the browser and comment back.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "stop": "node scripts/dev.mjs --stop",
    "restart": "pnpm stop && pnpm start",
    "start": "pnpm --filter @showcase/viewer build && node packages/server/index.ts",
    "serve": "node packages/cli/bin/showcase.js serve",
    "build:viewer": "pnpm --filter @showcase/viewer build",
    "mcp": "node packages/mcp/server.ts",
    "test": "node --test 'test/**/*.test.ts'",
    "typecheck": "tsc -p tsconfig.json --noEmit && pnpm -r typecheck",
    "lint": "oxlint . --deny-warnings && node scripts/check-core-boundary.mjs",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test:e2e": "playwright test",
    "test:e2e:chrome": "E2E_CHROME=1 playwright test --project=chrome"
  },
  "devDependencies": {
    "@hono/node-server": "^1.14.0",
    "@playwright/test": "^1.61.1",
    "@showcase/core": "workspace:*",
    "@showcase/server": "workspace:*",
    "@types/node": "^25.9.3",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.18"
  }
}
