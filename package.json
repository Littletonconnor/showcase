{
  "name": "showcase",
  "version": "0.1.0",
  "private": true,
  "description": "A live visual surface for terminal coding agents — agents publish surfaces (diagrams, diffs, markdown, mermaid, html) and you watch them render in the browser and comment back.",
  "license": "MIT",
  "bin": {
    "showcase": "bin/showcase.js"
  },
  "type": "module",
  "scripts": {
    "dev": "vite build && (vite build --watch & SHOWCASE_DEV=1 node --watch-path=./server --watch-path=./viewer/dist server/index.ts)",
    "start": "vite build && node server/index.ts",
    "serve": "node bin/showcase.js serve",
    "build:viewer": "vite build",
    "mcp": "node mcp/server.ts",
    "test": "node --test 'test/**/*.test.ts'",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.viewer.json --noEmit",
    "lint": "oxlint . --deny-warnings",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@pierre/diffs": "^1.2.11",
    "@vscode/markdown-it-katex": "^1.1.2",
    "ansi_up": "^6.0.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.7.0",
    "katex": "^0.17.0",
    "lucide-react": "^1.21.0",
    "radix-ui": "^1.6.0",
    "recharts": "^3.9.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "markdown-it": "^14.2.0",
    "mermaid": "^11.15.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shiki": "^4.2.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-singlefile": "^2.3.3",
    "zustand": "^5.0.14"
  },
  "engines": {
    "node": ">=22.18"
  }
}
